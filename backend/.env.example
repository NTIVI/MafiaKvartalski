# Database connection (PostgreSQL / Neon URL)
DATABASE_URL="postgresql://user:password@hostname:5432/dbname?sslmode=require"

# Server Port
PORT=4000

# Node Environment
NODE_ENV=development

# Allowed Frontend Vercel URL (e.g. https://your-game-app.vercel.app)
FRONTEND_URL="http://localhost:3000"

# External URL of Render Web Service (automatically populated by Render, or set manually)
# RENDER_EXTERNAL_URL="https://kvartalski-mafia-backend.onrender.com"
